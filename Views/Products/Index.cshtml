@model IEnumerable<LojaVirtual.Models.Product>

@{
    ViewData["Title"] = "Produtos";
}

<div class="container py-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">

        <div>
            <h1 class="fw-bold mb-1">Produtos</h1>
            <p class="text-muted mb-0">
                Gerencie os produtos da sua loja virtual
            </p>
        </div>

        <a asp-action="Create"
           class="btn btn-dark btn-lg rounded-3 shadow-sm">

            <i class="bi bi-plus-circle me-2"></i>
            Novo Produto
        </a>

    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Imagem</th>
                        <th>Produto</th>
                        <th>Preço</th>
                        <th>Estoque</th>
                        <th class="text-center pe-4">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- IMAGEM (AGORA VIA PRODUCTMEDIAS) -->
                                <td class="ps-4">

                                    @{
                                        var image = item.ProductMedias?
                                            .FirstOrDefault(x => x.Type == "image");
                                    }

                                    @if (image != null)
                                    {
                                        <img src="@image.Url"
                                             alt="@item.Name"
                                             class="rounded-3 border"
                                             style="width:90px;height:90px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center"
                                             style="width:90px;height:90px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }

                                </td>

                                <td>

                                    <div>
                                        <h5 class="fw-semibold mb-1">
                                            @item.Name
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            @item.Description
                                        </p>
                                    </div>

                                </td>

                                <td>
                                    <span class="fw-bold text-success fs-5">
                                        @item.Price.ToString("C")
                                    </span>
                                </td>

                                <td>

                                    @if (item.Stock > 0)
                                    {
                                        <span class="badge bg-success px-3 py-2 rounded-pill">
                                            @item.Stock em estoque
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill">
                                            Sem estoque
                                        </span>
                                    }

                                </td>

                                <td class="text-center pe-4">

                                    <div class="d-flex flex-column flex-md-row gap-2 justify-content-center">

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm rounded-3">
                                            <i class="bi bi-pencil-square me-1"></i>
                                            Editar
                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-secondary btn-sm rounded-3">
                                            <i class="bi bi-eye me-1"></i>
                                            Detalhes
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm rounded-3">
                                            <i class="bi bi-trash me-1"></i>
                                            Excluir
                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">

                                <div class="d-flex flex-column align-items-center">

                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mb-3"
                                         style="width:90px;height:90px;">

                                        <i class="bi bi-box-seam fs-1 text-secondary"></i>

                                    </div>

                                    <h4 class="fw-bold mb-2">
                                        Nenhum produto cadastrado
                                    </h4>

                                    <p class="text-muted mb-4">
                                        Comece adicionando o primeiro produto da sua loja.
                                    </p>

                                    <a asp-action="Create"
                                       class="btn btn-dark rounded-3 px-4 py-2">
                                        Criar Produto
                                    </a>

                                </div>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>