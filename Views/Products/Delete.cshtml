@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body p-4 p-md-5 text-center">

                    <div class="mb-4">

                        <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center"
                             style="width:90px;height:90px;">

                            <i class="bi bi-trash fs-1 text-danger"></i>

                        </div>

                    </div>

                    <h1 class="fw-bold mb-3">
                        Excluir Produto
                    </h1>

                    <p class="text-muted mb-4">
                        Tem certeza que deseja excluir este produto?
                    </p>

                    <div class="card bg-light border-0 rounded-4 mb-4">

                        <div class="card-body">

                            <img src="@Model.ImageUrl"
                                 class="rounded-3 mb-3"
                                 width="120" />

                            <h4 class="fw-bold">
                                @Model.Name
                            </h4>

                            <p class="text-muted">
                                @Model.Description
                            </p>

                            <h5 class="text-success fw-bold">
                                @Model.Price.ToString("C")
                            </h5>

                        </div>

                    </div>

                    <form asp-action="Delete">

                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-center gap-3">

                            <button type="submit"
                                    class="btn btn-danger btn-lg rounded-3 px-4">

                                <i class="bi bi-trash me-2"></i>
                                Excluir
                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary btn-lg rounded-3">

                                Cancelar
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>