@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = "Editar Produto";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body p-4 p-md-5">

                    <div class="mb-4">

                        <h1 class="fw-bold mb-1">
                            Editar Produto
                        </h1>

                        <p class="text-muted">
                            Atualize as informações do produto
                        </p>

                    </div>

                    <form asp-action="Edit" enctype="multipart/form-data">

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3 text-center">
                            <img src="@Model.ImageUrl" width="120" class="mb-3 rounded shadow" />
                        </div>

                        <div class="mb-4">

                            <label asp-for="Name" class="form-label fw-semibold"></label>

                            <input asp-for="Name"
                                   class="form-control form-control-lg rounded-3" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label fw-semibold"></label>

                            <textarea asp-for="Description"
                                      class="form-control rounded-3"
                                      rows="4"></textarea>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-4">

                                <label asp-for="Price"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="Price"
                                       class="form-control form-control-lg rounded-3" />

                            </div>

                            <div class="col-md-6 mb-4">

                                <label asp-for="Stock"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="Stock"
                                       class="form-control form-control-lg rounded-3" />

                            </div>

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Trocar Imagem
                            </label>

                            <input type="file" name="imageFile" class="form-control form-control-lg rounded-3" />

                            <span class="text-muted small">
                                Deixe vazio para manter a imagem atual
                            </span>

                        </div>

                        <div class="d-flex gap-3">

                            <button type="submit"
                                    class="btn btn-primary btn-lg rounded-3 px-4">

                                <i class="bi bi-pencil-square me-2"></i>
                                Atualizar
                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary btn-lg rounded-3">

                                Voltar
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>