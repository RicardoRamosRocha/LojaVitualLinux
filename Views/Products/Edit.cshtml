@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = "Editar Produto";
}

<partial name="_Navbar" />

<section class="py-5">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-9">

                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                    <div class="card-body p-4 p-lg-5">

                        <!-- HEADER -->
                        <div class="mb-5">

                            <span class="text-uppercase small text-muted fw-semibold">
                                Painel Administrativo
                            </span>

                            <h1 class="fw-bold mt-2 mb-2">
                                Editar Produto
                            </h1>

                            <p class="text-muted mb-0">
                                Atualize as informações e mídias do produto.
                            </p>

                        </div>

                        <!-- FORM -->
                        <form asp-action="Edit"
                              enctype="multipart/form-data">

                            <input type="hidden" asp-for="Id" />

                            <!-- NOME -->
                            <div class="mb-4">

                                <label asp-for="Name"
                                       class="form-label fw-semibold">
                                    Nome do Produto
                                </label>

                                <input asp-for="Name"
                                       class="form-control form-control-lg rounded-3" />

                                <span asp-validation-for="Name"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- DESCRIÇÃO -->
                            <div class="mb-4">

                                <label asp-for="Description"
                                       class="form-label fw-semibold">
                                    Descrição
                                </label>

                                <textarea asp-for="Description"
                                          class="form-control rounded-3"
                                          rows="5"></textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- PREÇO + ESTOQUE -->
                            <div class="row">

                                <div class="col-md-6 mb-4">

                                    <label asp-for="Price"
                                           class="form-label fw-semibold">
                                        Preço
                                    </label>

                                    <input asp-for="Price" type="number" step="0.01" min="0"
                                           class="form-control form-control-lg rounded-3" />

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label asp-for="Stock"
                                           class="form-label fw-semibold">
                                        Estoque
                                    </label>

                                    <input asp-for="Stock" type="number" min="0"
                                           class="form-control form-control-lg rounded-3" />

                                </div>

                            </div>

                            <!-- NOVAS IMAGENS -->
                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Adicionar Novas Imagens
                                </label>

                                <input type="file"
                                       name="imageFiles"
                                       multiple
                                       accept="image/*"
                                       class="form-control form-control-lg rounded-3" />

                                <div class="form-text">
                                    Você pode selecionar várias imagens.
                                </div>

                            </div>

                            <!-- NOVOS VIDEOS -->
                            <div class="mb-5">

                                <label class="form-label fw-semibold">
                                    Adicionar Novos Vídeos
                                </label>

                                <input type="file"
                                       name="videoFiles"
                                       multiple
                                       accept="video/mp4"
                                       class="form-control form-control-lg rounded-3" />

                                <div class="form-text">
                                    Você pode selecionar vários vídeos MP4.
                                </div>

                            </div>

                            <!-- GALERIA -->
                            @if (Model.ProductMedias != null &&
                                 Model.ProductMedias.Any())
                            {
                                <div class="mb-5">

                                    <h4 class="fw-bold mb-4">
                                        Mídias atuais
                                    </h4>

                                    <div class="row g-4">

                                        @foreach (var media in Model.ProductMedias)
                                        {
                                            <div class="col-md-4">

                                                <div class="border rounded-4 p-2 shadow-sm">

                                                    @if (media.Type == "image")
                                                    {
                                                        <img src="@media.Url"
                                                             class="img-fluid rounded-3"
                                                             style="height:250px;
                                                                    width:100%;
                                                                    object-fit:cover;" />
                                                    }
                                                    else
                                                    {
                                                        <video controls
                                                               class="w-100 rounded-3"
                                                               style="height:250px;
                                                                      object-fit:cover;">

                                                            <source src="@media.Url"
                                                                    type="video/mp4">

                                                        </video>
                                                    }

                                                    <!-- REMOVER -->
                                                    <a asp-action="DeleteMedia"
                                                       asp-route-id="@media.Id"
                                                       class="btn btn-danger w-100 rounded-3 mt-3">

                                                        <i class="bi bi-trash me-2"></i>
                                                        Remover

                                                    </a>

                                                </div>

                                            </div>
                                        }

                                    </div>

                                </div>
                            }

                            <!-- BOTÕES -->
                            <div class="d-flex flex-wrap gap-3">

                                <button type="submit"
                                        class="btn btn-dark btn-lg rounded-pill px-5">

                                    <i class="bi bi-check-circle me-2"></i>
                                    Atualizar Produto

                                </button>

                                <a asp-action="Index"
                                   class="btn btn-outline-dark btn-lg rounded-pill px-5">

                                    Voltar

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<partial name="_Footer" />

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}