@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body p-4 p-md-5">

                    <div class="mb-4">

                        <h1 class="fw-bold mb-1">
                            Novo Produto
                        </h1>

                        <p class="text-muted">
                            Cadastre um novo produto na loja
                        </p>

                    </div>

                    <form asp-action="Create" enctype="multipart/form-data">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger"></div>

                        <div class="mb-4">

                            <label asp-for="Name" class="form-label fw-semibold"></label>

                            <input asp-for="Name"
                                   class="form-control form-control-lg rounded-3" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label fw-semibold"></label>

                            <textarea asp-for="Description"
                                      class="form-control rounded-3"
                                      rows="4"></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger"></span>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-4">

                                <label asp-for="Price"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="Price"
                                       class="form-control form-control-lg rounded-3" />

                                <span asp-validation-for="Price"
                                      class="text-danger"></span>

                            </div>

                            <div class="col-md-6 mb-4">

                                <label asp-for="Stock"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="Stock"
                                       class="form-control form-control-lg rounded-3" />

                                <span asp-validation-for="Stock"
                                      class="text-danger"></span>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Imagem
                            </label>

                            <input type="file" name="imageFile" class="form-control" accept="image/*" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Vídeo
                            </label>

                            <input type="file" name="videoFile" class="form-control" accept="video/mp4" />

                        </div>

                        <div class="d-flex gap-3">

                            <button type="submit"
                                    class="btn btn-dark btn-lg rounded-3 px-4">

                                <i class="bi bi-check-circle me-2"></i>
                                Salvar
                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary btn-lg rounded-3">

                                Voltar
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>