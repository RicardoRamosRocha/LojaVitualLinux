@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = "Novo Produto";
}

<partial name="_Navbar" />

<section class="py-5">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                    <div class="card-body p-4 p-lg-5">

                        <!-- HEADER -->
                        <div class="mb-5">

                            <span class="text-uppercase small text-muted fw-semibold">
                                Painel Administrativo
                            </span>

                            <h1 class="fw-bold mt-2 mb-2">
                                Novo Produto
                            </h1>

                            <p class="text-muted mb-0">
                                Adicione um novo produto à vitrine da Angel Acessórios.
                            </p>

                        </div>

                        <!-- FORM -->
                        <form asp-action="Create"
                              enctype="multipart/form-data">

                            <div asp-validation-summary="ModelOnly"
                                 class="alert alert-danger rounded-3">
                            </div>

                            <!-- NOME -->
                            <div class="mb-4">

                                <label asp-for="Name"
                                       class="form-label fw-semibold">
                                    Nome do Produto
                                </label>

                                <input asp-for="Name"
                                       class="form-control form-control-lg rounded-3"
                                       placeholder="Ex: Colar Espírito Santo" />

                                <span asp-validation-for="Name"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- DESCRIÇÃO -->
                            <div class="mb-4">

                                <label asp-for="Description"
                                       class="form-label fw-semibold">
                                    Descrição
                                </label>

                                <textarea asp-for="Description"
                                          class="form-control rounded-3"
                                          rows="5"
                                          placeholder="Descrição do produto...">
                                </textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger small">
                                </span>

                            </div>

                            <!-- PREÇO + ESTOQUE -->
                            <div class="row">

                                <div class="col-md-6 mb-4">

                                    <label asp-for="Price"
                                           class="form-label fw-semibold">
                                        Preço
                                    </label>

                                    <input asp-for="Price"
                                           class="form-control form-control-lg rounded-3"
                                           placeholder="0,00" />

                                    <span asp-validation-for="Price"
                                          class="text-danger small">
                                    </span>

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label asp-for="Stock"
                                           class="form-label fw-semibold">
                                        Estoque
                                    </label>

                                    <input asp-for="Stock"
                                           class="form-control form-control-lg rounded-3"
                                           placeholder="0" />

                                    <span asp-validation-for="Stock"
                                          class="text-danger small">
                                    </span>

                                </div>

                            </div>

                            <!-- IMAGEM -->
                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Imagem do Produto
                                </label>

                                <input type="file"
                                       name="imageFile"
                                       class="form-control form-control-lg rounded-3"
                                       accept="image/*" />

                                <div class="form-text">
                                    JPG, PNG ou WEBP
                                </div>

                            </div>

                            <!-- VÍDEO -->
                            <div class="mb-5">

                                <label class="form-label fw-semibold">
                                    Vídeo do Produto
                                </label>

                                <input type="file"
                                       name="videoFile"
                                       class="form-control form-control-lg rounded-3"
                                       accept="video/mp4" />

                                <div class="form-text">
                                    Vídeo MP4 para reels e vitrine
                                </div>

                            </div>

                            <!-- BOTÕES -->
                            <div class="d-flex flex-wrap gap-3">

                                <button type="submit"
                                        class="btn btn-dark btn-lg rounded-pill px-5">

                                    <i class="bi bi-check-circle me-2"></i>
                                    Salvar Produto

                                </button>

                                <a asp-action="Index"
                                   class="btn btn-outline-dark btn-lg rounded-pill px-5">

                                    Voltar

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<partial name="_Footer" />

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}