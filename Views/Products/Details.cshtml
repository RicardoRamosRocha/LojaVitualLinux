@model LojaVirtual.Models.Product

@{
ViewData["Title"] = Model.Name;
}

<partial name="_Navbar" />

<div class="product-page">

```
<section class="py-5">

    <div class="container">

        <div class="row g-5">

            <!-- GALERIA -->
            <div class="col-lg-6">

                @if (Model.ProductMedias != null &&
                     Model.ProductMedias.Any())
                {
                    <div id="productCarousel"
                         class="carousel slide"
                         data-bs-ride="carousel">

                        <div class="carousel-inner rounded-4 shadow">

                            @{
                                var medias = Model.ProductMedias.ToList();
                            }

                            @for (int i = 0; i < medias.Count; i++)
                            {
                                var media = medias[i];

                                <div class="carousel-item @(i == 0 ? "active" : "")">

                                    @if (media.Type == "image")
                                    {
                                        <img src="@media.Url"
                                             alt="@Model.Name"
                                             class="d-block w-100 gallery-image" />
                                    }
                                    else
                                    {
                                        <video controls
                                               class="w-100 gallery-image">

                                            <source src="@media.Url"
                                                    type="video/mp4">

                                        </video>
                                    }

                                </div>
                            }

                        </div>

                        <button class="carousel-control-prev"
                                type="button"
                                data-bs-target="#productCarousel"
                                data-bs-slide="prev">

                            <span class="carousel-control-prev-icon"></span>

                        </button>

                        <button class="carousel-control-next"
                                type="button"
                                data-bs-target="#productCarousel"
                                data-bs-slide="next">

                            <span class="carousel-control-next-icon"></span>

                        </button>

                    </div>

                    <!-- MINIATURAS -->

                    <div class="d-flex flex-wrap gap-3 mt-4">

                        @for (int i = 0; i < medias.Count; i++)
                        {
                            var media = medias[i];

                            <button type="button"
                                    data-bs-target="#productCarousel"
                                    data-bs-slide-to="@i"
                                    class="border-0 bg-transparent p-0">

                                @if (media.Type == "image")
                                {
                                    <img src="@media.Url"
                                         class="thumb-image" />
                                }
                                else
                                {
                                    <div class="thumb-video">

                                        <i class="bi bi-play-fill fs-2"></i>

                                    </div>
                                }

                            </button>
                        }

                    </div>

                }

            </div>

            <!-- DADOS -->

            <div class="col-lg-6">

                <span class="badge bg-dark rounded-pill px-3 py-2 mb-3">

                    Angel Acessórios

                </span>

                <h1 class="fw-bold display-5 mb-3">

                    @Model.Name

                </h1>

                @if (Model.Category != null)
                {
                    <p class="text-muted mb-4">

                        Categoria:
                        <strong>@Model.Category.Name</strong>

                    </p>
                }

                <div class="fs-1 fw-bold text-dark mb-4">

                    @Model.Price.ToString("C")

                </div>

                <p class="text-muted fs-5 mb-4">

                    @Model.Description

                </p>

                <div class="mb-5">

                    @if (Model.Stock > 0)
                    {
                        <span class="badge bg-success px-4 py-3 rounded-pill fs-6">

                            <i class="bi bi-check-circle me-2"></i>

                            @Model.Stock unidades disponíveis

                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger px-4 py-3 rounded-pill fs-6">

                            Sem estoque

                        </span>
                    }

                </div>

                <div class="d-flex flex-wrap gap-3">

                    <a asp-controller="Cart"
                       asp-action="Add"
                       asp-route-id="@Model.Id"
                       class="btn btn-dark btn-lg rounded-pill px-5">

                        <i class="bi bi-cart me-2"></i>

                        Adicionar ao Carrinho

                    </a>

                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="btn btn-outline-dark btn-lg rounded-pill px-5">

                        Ver Carrinho

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

@if (ViewBag.RelatedProducts != null)
{
    <section class="py-5 bg-light">

        <div class="container">

            <h3 class="fw-bold mb-4">

                Você também pode gostar

            </h3>

            <partial name="_ProductGrid"
                     model="ViewBag.RelatedProducts" />

        </div>

    </section>
}
