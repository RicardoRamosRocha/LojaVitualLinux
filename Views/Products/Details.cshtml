@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<partial name="_Navbar" />

<section class="py-5">

    <div class="container">

        <div class="row g-5 align-items-center">

            <!-- MEDIA -->
            <div class="col-lg-6">

                <div class="bg-white rounded-4 shadow-sm p-3">

                    @{
                        var video = Model.ProductMedias?
                            .FirstOrDefault(x => x.Type == "video")?.Url;

                        var images = Model.ProductMedias?
                            .Where(x => x.Type == "image")
                            .ToList();
                    }

                    @if (!string.IsNullOrEmpty(video))
                    {
                        <video controls class="w-100 rounded-4">
                            <source src="@video" type="video/mp4">
                        </video>
                    }
                    else if (images != null && images.Any())
                    {
                        <img src="@images.First().Url"
                             class="img-fluid rounded-4 w-100"
                             alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="text-muted text-center py-5">
                            Sem mídia disponível
                        </div>
                    }

                </div>

            </div>

            <!-- INFO -->
            <div class="col-lg-6">

                <span class="badge bg-dark rounded-pill px-3 py-2 mb-3">
                    Angel Acessórios
                </span>

                <h1 class="fw-bold display-5 mb-3">
                    @Model.Name
                </h1>

                <div class="fs-2 fw-bold text-dark mb-4">
                    R$ @Model.Price
                </div>

                <p class="text-muted fs-5 mb-4">
                    @Model.Description
                </p>

                <div class="d-flex align-items-center gap-3 mb-5">

                    <span class="fw-semibold">Estoque:</span>

                    <span class="badge bg-success px-3 py-2 rounded-pill">
                        @Model.Stock disponível
                    </span>

                </div>

                <!-- BOTÕES -->
                <div class="d-flex flex-wrap gap-3">

                    <a href="https://wa.me/5531988078334?text=Olá, tenho interesse no produto @Model.Name"
                       target="_blank"
                       class="btn btn-dark btn-lg rounded-pill px-5">

                        <i class="bi bi-whatsapp me-2"></i>
                        Comprar no WhatsApp

                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-dark btn-lg rounded-pill px-5">

                        Voltar

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<partial name="_Footer" />