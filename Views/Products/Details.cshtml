@model LojaVirtual.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<partial name="_Navbar" />

<section class="product-details-section">

    <div class="container">

        <div class="product-details-box">

            <div class="row g-5 align-items-center">

                <!-- IMAGEM -->
                <div class="col-lg-6">

                    <div class="product-image-wrapper">

                        <img src="@Model.ImageUrl"
                             alt="@Model.Name"
                             class="product-details-image">

                    </div>

                </div>

                <!-- INFO -->
                <div class="col-lg-6">

                    <div class="product-details-content">

                        <span class="product-details-category">
                            Angel Acessórios
                        </span>

                        <h1 class="product-details-title">
                            @Model.Name
                        </h1>

                        <div class="product-details-price">

                            @Model.Price.ToString("C")

                        </div>

                        <p class="product-details-description">

                            @Model.Description

                        </p>

                        <!-- ESTOQUE -->
                        <div class="product-stock mb-4">

                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success px-3 py-2 rounded-pill">
                                    Em estoque
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger px-3 py-2 rounded-pill">
                                    Indisponível
                                </span>
                            }

                        </div>

                        <!-- BOTÕES -->
                        <div class="product-buttons">

                            <a href="https://wa.me/5531999999999?text=Olá,%20tenho%20interesse%20no%20produto%20@Model.Name"
                               target="_blank"
                               class="btn btn-dark-custom">

                                <i class="bi bi-whatsapp me-2"></i>
                                Comprar no WhatsApp

                            </a>

                            <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-light-custom">

                                Voltar

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<partial name="_Footer" />