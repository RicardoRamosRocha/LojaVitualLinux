@model IEnumerable<LojaVirtual.Models.Product>

<section id="catalogo" class="products-section">

    <div class="container">

        <div class="row g-4">

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var image = item.ProductMedias?
                        .FirstOrDefault(x => x.Type == "image")?.Url;

                    <div class="col-md-6 col-lg-4">

                        <a asp-controller="Products"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="text-decoration-none text-dark">

                            <div class="product-card h-100">

                                <img src="@(image ?? "/images/placeholder.png")"
                                     alt="@item.Name"
                                     class="product-image" />

                                <div class="product-content">

                                    <span class="product-category">
                                        Angel Acessórios
                                    </span>

                                    <h3 class="product-name">
                                        @item.Name
                                    </h3>

                                    <p class="product-description">
                                        @item.Description
                                    </p>

                                    <div class="product-price">
                                        @item.Price.ToString("C")
                                    </div>

                                </div>

                            </div>

                        </a>

                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">

                    <h4 class="fw-bold">Nenhum produto cadastrado</h4>

                    <p class="text-muted">Adicione produtos no painel administrativo.</p>

                </div>
            }

        </div>

    </div>

</section>