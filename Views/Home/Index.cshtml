@model IEnumerable<LojaVirtual.Models.Product>

@{
    ViewData["Title"] = "Angel Acessórios";
}

<partial name="_Navbar" />

<section class="hero-section">

    <div class="container">

        <div class="hero-box">

            <div class="row align-items-center">

                <div class="col-lg-6">

                    <div class="hero-content">

                        <span class="hero-tag">
                            NOVA COLEÇÃO
                        </span>

                        <h1 class="hero-title">
                            Elegância em cada detalhe
                        </h1>

                        <p class="hero-text">

                            Acessórios sofisticados para mulheres modernas,
                            elegantes e autênticas.

                        </p>

                        <div class="hero-buttons">

                            <a href="#catalogo"
                               class="btn btn-dark-custom">

                                Ver Coleção

                            </a>

                            <a href="#contato"
                               class="btn btn-light-custom">

                                WhatsApp

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="hero-image">

                        <video autoplay muted loop playsinline class="hero-video">

                            <source src="/videos/products/Video Home.mp4"
                                    type="video/mp4">

                        </video>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<section id="catalogo" class="products-section">

    <div class="container">

        <div class="section-header">

            <h2>
                Produtos em destaque
            </h2>

            <p>
                Descubra os modelos mais desejados da coleção.
            </p>

        </div>

        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="product-card">

                        <img src="@item.ImageUrl"
                             alt="@item.Name">

                        <div class="product-content">

                            <span class="product-category">
                                Angel Acessórios
                            </span>

                            <h3 class="product-name">
                                @item.Name
                            </h3>

                            <p class="product-description">
                                @item.Description
                            </p>

                            <div class="product-price">
                                R$ @item.Price
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</section>

<footer id="contato" class="footer-section">

    <div class="container">

        <div class="footer-box">

            <h2>
                Angel Acessórios
            </h2>

            <p>
                Sofisticação, delicadeza e elegância.
            </p>

            <div class="footer-social">

                <a href="#">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="#">
                    <i class="bi bi-whatsapp"></i>
                </a>

            </div>

        </div>

    </div>

</footer>